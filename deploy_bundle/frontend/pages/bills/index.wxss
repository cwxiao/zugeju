.bill-shell {
  gap: 16rpx;
}

.bill-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.bill-item {
  padding: 28rpx;
  background: #fffaf3;
}

.bill-empty-card {
  padding: 32rpx;
}

.bill-title {
  font-size: 28rpx;
  font-weight: 600;
}

.bill-meta {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b5e4f;
}

.bill-summary-card {
  background: linear-gradient(145deg, rgba(241, 250, 255, 0.98) 0%, rgba(255, 236, 214, 0.95) 100%);
}

.bill-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.bill-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 246, 0.72);
  color: #7c6551;
  font-size: 22rpx;
}

.bill-total {
  display: block;
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #2f2218;
}

.bill-input {
  width: 100%;
  height: 88rpx;
  margin-top: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 22rpx 32rpx 22rpx 28rpx;
  background: rgba(255, 251, 246, 0.78);
  border: 1rpx solid rgba(176, 125, 71, 0.14);
  color: #2e241b;
  font-size: 26rpx;
}

.bill-record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.bill-record-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0e6d8;
}

.bill-record-title {
  display: block;
  font-size: 26rpx;
  color: #2f2218;
}

.bill-record-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8d7c69;
}

.bill-record-amount {
  font-size: 26rpx;
  color: #6b5e4f;
}

.bill-record-amount-strong {
  color: #b86122;
  font-weight: 600;
}

.bill-action-wrap {
  margin-top: 8rpx;
}