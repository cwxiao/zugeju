page {
  background: linear-gradient(180deg, #edf9ff 0%, #f6f2ea 34%, #fff0df 100%);
  color: #1f1a14;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero-card,
.panel,
.nav-card,
.activity-card,
.bill-card,
.form-card,
.summary-card,
.empty-card {
  background: #fcfdff;
  border-radius: 34rpx 88rpx 42rpx 74rpx;
  box-shadow: 0 18rpx 40rpx rgba(38, 95, 145, 0.1);
  border: 1rpx solid rgba(44, 154, 219, 0.08);
}

.ad-slot-card {
  position: relative;
  overflow: hidden;
  margin-top: 18rpx;
  padding: 28rpx;
  border-radius: 30rpx 72rpx 34rpx 58rpx;
  background: linear-gradient(135deg, rgba(236, 247, 255, 0.96) 0%, rgba(255, 235, 214, 0.94) 100%);
  border: 1rpx dashed rgba(43, 150, 204, 0.28);
  box-shadow: 0 14rpx 30rpx rgba(43, 109, 154, 0.1);
}

.ad-slot-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(19, 155, 215, 0.12);
  color: #0f76a0;
  font-size: 22rpx;
}

.ad-slot-title {
  display: block;
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #2f2218;
}

.ad-slot-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6f5e4e;
}

.ad-slot-footnote {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #a16939;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.section-desc {
  font-size: 26rpx;
  color: #5d6f82;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(22, 175, 239, 0.1);
  color: #0f76a0;
  font-size: 24rpx;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #139bd7 0%, #ff7b1f 100%);
  color: #fff8f1;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 32rpx rgba(27, 109, 158, 0.24);
}

.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: rgba(21, 172, 233, 0.1);
  color: #126f98;
  font-size: 28rpx;
}

.grid-two {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}