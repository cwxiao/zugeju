page {
  background: linear-gradient(180deg, #f6ead8 0%, #efe6db 38%, #f4efe7 100%);
  color: #1f1a14;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero-card,
.panel,
.nav-card,
.activity-card,
.bill-card,
.form-card,
.summary-card,
.empty-card {
  background: #fffaf3;
  border-radius: 34rpx 88rpx 42rpx 74rpx;
  box-shadow: 0 18rpx 40rpx rgba(76, 55, 30, 0.08);
  border: 1rpx solid rgba(150, 104, 54, 0.08);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.section-desc {
  font-size: 26rpx;
  color: #6b5e4f;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #efe2cf;
  color: #6f4c2e;
  font-size: 24rpx;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #cf7a36 0%, #b85d24 100%);
  color: #fff8f1;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 32rpx rgba(170, 91, 33, 0.24);
}

.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: #efe2cf;
  color: #7a5334;
  font-size: 28rpx;
}

.grid-two {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}