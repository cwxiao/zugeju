.personality-shell {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.personality-cover-card,
.personality-score-card,
.personality-title-card,
.personality-dna-card,
.personality-social-card,
.personality-activity-card,
.personality-finance-card,
.personality-radar-card,
.personality-sharp-card,
.personality-honor-card,
.personality-animal-card,
.personality-poster-card {
  padding: 30rpx;
}

.personality-cover-card {
  background: linear-gradient(145deg, rgba(234, 248, 255, 0.98) 0%, rgba(255, 222, 191, 0.95) 100%);
}

.personality-cover-kicker,
.personality-section-label,
.personality-cover-meta {
  display: block;
  font-size: 22rpx;
  color: #8b725b;
}

.personality-cover-title,
.personality-main-title,
.personality-poster-title {
  display: block;
  color: #2f2218;
  font-weight: 700;
}

.personality-cover-title {
  margin-top: 20rpx;
  font-size: 42rpx;
  line-height: 1.25;
}

.personality-cover-desc,
.personality-main-desc,
.personality-poster-desc,
.personality-quote,
.personality-poster-footer {
  display: block;
  font-size: 25rpx;
  line-height: 1.7;
  color: #665543;
}

.personality-cover-desc {
  margin-top: 16rpx;
}

.personality-cover-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 28rpx;
}

.personality-score-pill {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 249, 242, 0.76);
  color: #ae5f1f;
  font-size: 24rpx;
  font-weight: 700;
}

.personality-score-card {
  background: rgba(255, 252, 247, 0.95);
}

.personality-score-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
}

.personality-score-value {
  display: block;
  font-size: 86rpx;
  line-height: 1;
  font-weight: 700;
  color: #2f2218;
}

.personality-score-meta {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7d6b58;
}

.personality-score-ring {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 156rpx;
  height: 156rpx;
  border-radius: 999rpx;
  background: conic-gradient(from 180deg, #13a0dd 0%, #ff8b33 70%, rgba(255, 255, 255, 0.9) 100%);
}

.personality-radar-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.personality-radar-close {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(242, 151, 69, 0.14);
  color: #b96a28;
  font-size: 22rpx;
}

.personality-radar-wrap {
  position: relative;
  width: 520rpx;
  height: 520rpx;
  margin: 22rpx auto 0;
}

.personality-radar-grid,
.personality-radar-fill {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 300rpx;
  height: 300rpx;
  transform: translate(-50%, -50%);
  clip-path: polygon(50% 0%, 93% 25%, 93% 75%, 50% 100%, 7% 75%, 7% 25%);
}

.personality-radar-grid {
  background: rgba(19, 160, 221, 0.08);
  border: 2rpx solid rgba(19, 160, 221, 0.18);
  box-shadow: inset 0 0 0 52rpx rgba(255, 251, 246, 0.72), inset 0 0 0 104rpx rgba(19, 160, 221, 0.06);
}

.personality-radar-fill {
  background: linear-gradient(135deg, rgba(19, 160, 221, 0.66) 0%, rgba(255, 139, 51, 0.72) 100%);
  opacity: 0.86;
}

.personality-radar-axis {
  position: absolute;
  width: 144rpx;
  text-align: center;
}

.radar-axis-1 { left: 188rpx; top: 0; }
.radar-axis-2 { right: 0; top: 112rpx; }
.radar-axis-3 { right: 0; bottom: 96rpx; }
.radar-axis-4 { left: 188rpx; bottom: 0; }
.radar-axis-5 { left: 0; bottom: 96rpx; }
.radar-axis-6 { left: 0; top: 112rpx; }

.personality-radar-label,
.personality-radar-percent {
  display: block;
  font-size: 22rpx;
  color: #2f2218;
}

.personality-radar-percent {
  margin-top: 6rpx;
  color: #8b725b;
}

.personality-score-ring-text {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 999rpx;
  background: #fff8f0;
  color: #2f2218;
  font-size: 26rpx;
  font-weight: 600;
}

.personality-main-title {
  margin-top: 16rpx;
  font-size: 44rpx;
}

.personality-subtitle {
  font-size: 40rpx;
}

.personality-main-desc {
  margin-top: 14rpx;
}

.dna-row {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr) 88rpx;
  gap: 16rpx;
  align-items: center;
  margin-top: 18rpx;
}

.dna-name,
.dna-percent {
  font-size: 24rpx;
  color: #2f2218;
}

.dna-bar-track {
  height: 20rpx;
  border-radius: 999rpx;
  background: rgba(19, 160, 221, 0.09);
  overflow: hidden;
}

.dna-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #18a3e0 0%, #ff8b33 100%);
}

.personality-stat-grid,
.personality-activity-grid,
.personality-finance-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.personality-stat-card,
.personality-activity-item {
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(244, 250, 255, 0.82);
}

.personality-activity-item-wide {
  grid-column: span 2;
}

.personality-finance-total {
  display: block;
  margin-top: 16rpx;
  font-size: 56rpx;
  line-height: 1.15;
  font-weight: 700;
  color: #2f2218;
}

.personality-finance-wide {
  grid-column: span 2;
}

.personality-finance-tabs {
  margin-top: 22rpx;
}

.personality-finance-tab {
  min-width: 70rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(18, 152, 212, 0.08);
  color: #0f76a0;
  font-size: 24rpx;
  text-align: center;
}

.personality-finance-tab-active {
  background: linear-gradient(135deg, #139bd7 0%, #ff8b33 100%);
  color: #fff9f2;
}

.personality-finance-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 18rpx;
}

.personality-finance-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0e6d8;
}

.personality-finance-label {
  display: block;
  font-size: 27rpx;
  color: #2f2218;
  font-weight: 600;
}

.personality-finance-amount {
  font-size: 28rpx;
  color: #b86122;
  font-weight: 700;
}

.personality-stat-label {
  display: block;
  font-size: 22rpx;
  color: #87715d;
}

.personality-stat-value {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #2f2218;
  font-weight: 600;
}

.personality-quote {
  margin-top: 16rpx;
}

.personality-honor-row {
  margin-top: 18rpx;
}

.personality-honor-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 142, 57, 0.12);
  color: #b66422;
  font-size: 23rpx;
}

.personality-poster-title {
  margin-top: 16rpx;
  font-size: 36rpx;
}

.personality-poster-desc {
  margin-top: 14rpx;
}

.personality-poster-footer {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(242, 248, 255, 0.84);
}

.personality-poster-button {
  margin-top: 22rpx;
}