<view class="page-shell">
  <image class="page-bg-img" src="/img/city-bg.png" mode="aspectFill" />
  <view class="home-stage">
    <view wx:if="{{authVisible}}" class="auth-mask">
      <view class="auth-dialog">
        <image class="auth-logo" src="/img/brand-logo.png" mode="aspectFit" />
        <text class="auth-title">登录后更好用</text>
        <text class="auth-desc">获取头像和昵称后可创建活动、记账结算，也可先随便看看。</text>

        <!-- 已获取到头像和昵称：展示预览 -->
        <view wx:if="{{authAvatarUrl && authNickname}}" class="auth-preview" bindtap="reChooseAvatar">
          <image class="auth-preview-avatar" src="{{authAvatarUrl}}" mode="aspectFill" />
          <text class="auth-preview-nickname">{{authNickname}}</text>
          <text class="auth-preview-hint">点击可更换头像</text>
        </view>

        <!-- 未获取：显示获取按钮 -->
        <view wx:if="{{!authAvatarUrl || !authNickname}}" class="auth-action-area">
          <!-- 头像未获取 -->
          <button wx:if="{{!authAvatarUrl}}" class="auth-agree-button" open-type="chooseAvatar" bindchooseavatar="handleChooseAvatar">
            同意并获取头像
          </button>
          <!-- 头像已获取，昵称未获取 -->
          <view wx:if="{{authAvatarUrl && !authNickname}}" class="auth-nickname-row">
            <image class="auth-nickname-avatar" src="{{authAvatarUrl}}" mode="aspectFill" />
            <input class="auth-nickname-input"
                   type="nickname"
                   value="{{authNickname}}"
                   placeholder="点击获取微信昵称"
                   focus="{{authAvatarUrl && !authNickname}}"
                   bindblur="onNicknameBlur"
                   bindconfirm="onNicknameConfirm" />
          </view>
        </view>

        <!-- 都获取到了：确认登录 -->
        <button wx:if="{{authAvatarUrl && authNickname}}" class="auth-confirm-button" loading="{{authLoading}}" bindtap="confirmLogin">
          {{authLoading ? '登录中...' : '确认登录'}}
        </button>
        <text class="auth-section-tip auth-subscribe-tip">确认时会请求通知授权，可拒绝。</text>
        <view class="auth-close-row" bindtap="closeAuthDialog">
          <text class="auth-close-text">先随便看看</text>
        </view>
      </view>
    </view>

    <view class="stage-orb stage-orb-left"></view>
    <view class="stage-orb stage-orb-right"></view>
    <view class="stage-ribbon stage-ribbon-top"></view>
    <view class="stage-ribbon stage-ribbon-bottom"></view>
    <view class="stage-spark stage-spark-a"></view>
    <view class="stage-spark stage-spark-b"></view>

    <view class="hero-stack">
      <view class="hero-layer hero-layer-back"></view>
      <view class="hero-layer hero-layer-mid"></view>
      <view class="hero-card home-card home-card-theme">
        <view class="card-accent accent-home"></view>
        <view class="topbar">
          <view class="brand-wrap">
            <image class="minimal-logo" src="/img/brand-logo.png" mode="aspectFit" bindtap="goCreate" />
            <text class="minimal-brand">来整</text>
          </view>
          <view class="minimal-link" bindtap="goActivities">活动足迹</view>
        </view>

        <view class="cta-panel">
          <view>
            <text class="hero-title" bindtap="goCreate">整</text>
            <text class="hero-subtitle">想法先落下，时间地点再往里填。</text>
          </view>
          <view class="hero-cta-right">
            <image class="hero-character-img" src="{{cdnImg.UI_CHARACTER}}" mode="aspectFit" />
            <view class="primary-button minimal-button charge-btn {{charging ? 'charge-active' : ''}}" catchtouchstart="onChargeStart" catchtouchend="onChargeEnd">整!</view>
            <view wx:if="{{charging}}" class="charge-hint">蓄力中...</view>
          </view>
        </view>

        <view class="quick-entry-row">
          <view class="quick-entry-card quick-entry-card-solo" bindtap="goActivities">
            <text class="quick-entry-title">活动足迹</text>
            <text class="quick-entry-desc">回看以前整过的局。</text>
          </view>
          <!-- 活动分析入口暂时隐藏，代码保留 -->
          <!--
          <view class="quick-entry-card quick-entry-card-accent" bindtap="goPersonality">
            <text class="quick-entry-title">活动分析</text>
            <text class="quick-entry-desc">30 天整活风格总结。</text>
          </view>
          -->
        </view>
      </view>
    </view>

    <!--
    <view class="ad-slot-card">
      <text class="ad-slot-badge">广告位预留</text>
      <text class="ad-slot-title">首页推荐广告</text>
      <text class="ad-slot-desc">这里预留给首页信息流或横幅广告，后续可直接替换成微信广告组件。</text>
      <text class="ad-slot-footnote">建议放活动推荐、吃喝玩乐或本地商家合作位。</text>
    </view>
    -->

    <view class="section-head">
      <text class="section-title">我正在整的</text>
      <text class="section-desc">点进卡片看详情</text>
    </view>

    <view wx:if="{{!loggedIn}}" class="browse-mode">
      <view class="feature-cards">
        <view class="feature-card">
          <text class="feature-icon">🎯</text>
          <text class="feature-title">发起活动</text>
          <text class="feature-desc">聚餐、运动、游戏、旅行...一键发起，轻松邀约</text>
        </view>
        
        <view class="feature-card">
          <text class="feature-icon">👥</text>
          <text class="feature-title">邀请好友</text>
          <text class="feature-desc">生成邀请链接，微信一键分享，好友秒加入</text>
        </view>
        
        <view class="feature-card">
          <text class="feature-icon">📊</text>
          <text class="feature-title">活动统计</text>
          <text class="feature-desc">自动统计人数、AA付款、活动足迹，省心省力</text>
        </view>
      </view>

      <view class="browse-cta" bindtap="showAuth">
        <view class="ok-btn">
          <text class="ok-letter ok-o">o</text>
          <text class="ok-letter ok-k">k</text>
          <text class="ok-bang">!</text>
        </view>
        <text class="cta-hint">点这里登录</text>
      </view>
    </view>

    <view wx:if="{{loggedIn}}" class="card-list">
      <block wx:for="{{ongoingItems}}" wx:key="id">
        <view class="activity-card ongoing-card ongoing-theme" bindtap="goDetail" data-id="{{item.id}}">
          <view class="card-accent accent-item"></view>
          <view class="card-topline">
            <view class="tag-group">
              <text class="card-tag">{{item.tag}}</text>
              <text class="card-mode">{{item.mode}}</text>
            </view>
            <text class="card-arrow">查看</text>
          </view>
          <text class="card-title">{{item.title}}</text>
          <text class="card-meta">{{item.time}}</text>
          <text class="card-meta">{{item.place}}</text>
          <view class="card-footer">
            <view>
              <text class="card-status">{{item.status}}</text>
              <text class="card-count">{{item.count}}</text>
            </view>
            <view class="avatar-stack">
              <block wx:for="{{item.members}}" wx:key="*this">
                <view class="avatar-pill">{{item}}</view>
              </block>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 旋天阵联动侧边栏 -->
  <view class="game-drawer-tab" bindtap="toggleGameDrawer">
    <text class="game-drawer-tab-text">旋</text>
    <text class="game-drawer-tab-text">天</text>
    <text class="game-drawer-tab-text">阵</text>
  </view>
  <view wx:if="{{gameDrawerOpen}}" class="game-drawer-mask" bindtap="closeGameDrawer"></view>
  <view class="game-drawer-panel {{gameDrawerOpen ? 'game-drawer-panel-open' : ''}}">
    <view class="game-drawer-header">
      <text class="game-drawer-title">🎮 换个玩法？</text>
      <view class="game-drawer-close" bindtap="closeGameDrawer">✕</view>
    </view>
    <view class="game-drawer-body">
      <image class="game-drawer-cover" src="{{cdnImg.XUANTIANZHEN}}" mode="aspectFill" />
      <text class="game-drawer-name">旋天阵</text>
      <text class="game-drawer-desc">策略对弈，指尖排兵布阵</text>
      <view class="game-drawer-play-btn" bindtap="goToXuantianzhen">
        <text class="game-drawer-play-text">立即去玩 ▸</text>
      </view>
    </view>
  </view>
</view>