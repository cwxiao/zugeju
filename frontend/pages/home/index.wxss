.home-stage {
  position: relative;
  min-height: calc(100vh - 64rpx);
  padding-top: 8rpx;
  overflow: hidden;
}

.auth-mask {
  position: absolute;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(34, 24, 17, 0.42);
  backdrop-filter: blur(16rpx);
}

.auth-dialog {
  width: 100%;
  padding: 42rpx 34rpx;
  border-radius: 40rpx 100rpx 44rpx 78rpx;
  background: linear-gradient(145deg, rgba(234, 248, 255, 0.98) 0%, rgba(255, 228, 196, 0.96) 100%);
  box-shadow: 0 28rpx 64rpx rgba(22, 72, 116, 0.2);
}

.auth-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(19, 155, 215, 0.18), 0 0 0 4rpx rgba(255, 255, 255, 0.9);
}

.auth-title {
  display: block;
  margin-top: 28rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #2f2218;
}

.auth-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #735d4b;
}

.auth-section-tip {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8b6c54;
}

.auth-subscribe-tip {
  margin-top: 18rpx;
  text-align: center;
}

/* ===== 登录流程：获取区 ===== */

.auth-action-area {
  margin-top: 32rpx;
}

.auth-step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.auth-step-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2479a4;
  margin-bottom: 16rpx;
}

.auth-step-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #c4702a;
  text-align: center;
}

.auth-agree-button {
  width: 100%;
  height: 96rpx;
  margin-top: 8rpx;
  padding: 0;
  border: none;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #1198d4 0%, #ff7d21 100%);
  color: #fff9f3;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 20rpx 38rpx rgba(31, 111, 161, 0.24);
  box-sizing: border-box;
  line-height: 96rpx;
}

.auth-agree-button::after {
  border: none;
}

.auth-nickname-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(56, 151, 197, 0.18);
}

.auth-nickname-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.auth-nickname-input {
  flex: 1;
  height: 72rpx;
  font-size: 30rpx;
  color: #2f2218;
  font-weight: 600;
}

/* ===== 登录流程：预览区 ===== */

.auth-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 32rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(249, 252, 255, 0.84);
  box-shadow: inset 0 0 0 1rpx rgba(32, 163, 225, 0.1);
}

.auth-preview-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  border: 4rpx solid #fffaf3;
  box-shadow: 0 8rpx 20rpx rgba(31, 110, 160, 0.14);
}

.auth-preview-nickname {
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #2f2218;
}

.auth-preview-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8b6c54;
}

.auth-confirm-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  margin-top: 22rpx;
  padding: 0 30rpx;
  border: none;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #1198d4 0%, #ff7d21 100%);
  color: #fff9f3;
  box-shadow: 0 20rpx 38rpx rgba(31, 111, 161, 0.24);
  font-size: 30rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.auth-confirm-button::after {
  border: none;
}

.hero-stack {
  position: relative;
  padding-top: 42rpx;
}

.hero-layer {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  border: 1rpx solid rgba(168, 109, 64, 0.08);
}

.hero-layer-back {
  top: 0;
  bottom: 54rpx;
  background: linear-gradient(135deg, rgba(22, 180, 245, 0.24) 0%, rgba(255, 130, 37, 0.18) 100%);
  border-radius: 48rpx 126rpx 56rpx 94rpx;
  transform: rotate(-3deg);
}

.hero-layer-mid {
  top: 16rpx;
  bottom: 26rpx;
  left: 10rpx;
  right: 34rpx;
  background: linear-gradient(135deg, rgba(233, 249, 255, 0.88) 0%, rgba(255, 231, 201, 0.56) 100%);
  border-radius: 46rpx 118rpx 50rpx 88rpx;
  transform: rotate(-1.6deg);
}

.stage-orb {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(12rpx);
  opacity: 0.8;
}

.stage-orb-left {
  top: 30rpx;
  left: -80rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(18, 185, 247, 0.24);
}

.stage-orb-right {
  top: 200rpx;
  right: -70rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 136, 42, 0.24);
}

.stage-ribbon {
  position: absolute;
  height: 88rpx;
  border-radius: 999rpx;
  opacity: 0.55;
  transform: rotate(-12deg);
}

.stage-ribbon-top {
  top: 118rpx;
  left: -30rpx;
  width: 320rpx;
  background: linear-gradient(90deg, rgba(19, 181, 246, 0.18) 0%, rgba(255, 124, 33, 0.28) 100%);
}

.stage-ribbon-bottom {
  top: 520rpx;
  right: -40rpx;
  width: 280rpx;
  transform: rotate(16deg);
  background: linear-gradient(90deg, rgba(255, 157, 79, 0.12) 0%, rgba(24, 176, 240, 0.22) 100%);
}

.stage-spark {
  position: absolute;
  width: 26rpx;
  height: 26rpx;
  border-radius: 8rpx;
  transform: rotate(18deg);
}

.stage-spark-a {
  top: 164rpx;
  right: 120rpx;
  background: rgba(223, 114, 60, 0.42);
}

.stage-spark-b {
  top: 620rpx;
  left: 44rpx;
  background: rgba(214, 177, 82, 0.42);
}

.home-card {
  position: relative;
  padding: 28rpx;
  overflow: hidden;
  background: linear-gradient(145deg, rgba(244, 251, 255, 0.96) 0%, rgba(255, 234, 210, 0.9) 100%);
  backdrop-filter: blur(8rpx);
  border-radius: 38rpx 112rpx 44rpx 84rpx;
  z-index: 2;
}

.home-card-theme {
  background: linear-gradient(145deg, rgba(235, 248, 255, 0.98) 0%, rgba(255, 221, 186, 0.94) 100%);
  box-shadow: 0 26rpx 56rpx rgba(29, 102, 152, 0.16);
}

.card-accent {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.accent-home {
  top: -26rpx;
  right: 38rpx;
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(232, 158, 70, 0.28) 0%, rgba(232, 158, 70, 0) 72%);
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand-wrap {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.cta-panel {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 42rpx;
}

.hero-cta-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.hero-character-img {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.92;
  transform: rotate(-4deg);
  animation: heroFloat 3.2s ease-in-out infinite;
}

@keyframes heroFloat {
  0%, 100% { transform: translateY(0) rotate(-4deg); }
  50% { transform: translateY(-14rpx) rotate(-2deg); }
}

.quick-entry-row {
  margin-top: 26rpx;
}

.quick-entry-card-solo {
  width: 100%;
}

.quick-entry-card {
  min-height: 156rpx;
  padding: 22rpx;
  border-radius: 28rpx 44rpx 30rpx 40rpx;
  background: rgba(255, 250, 244, 0.72);
  border: 1rpx solid rgba(177, 125, 71, 0.12);
}

.quick-entry-card-accent {
  background: linear-gradient(145deg, rgba(232, 248, 255, 0.92) 0%, rgba(255, 234, 213, 0.88) 100%);
}

.quick-entry-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #2f2218;
}

.quick-entry-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7a6856;
}

.hero-title {
  display: block;
  font-size: 72rpx;
  line-height: 1;
  font-weight: 700;
  color: #2f2218;
}

.hero-subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7d6a57;
}

.minimal-link {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(244, 232, 216, 0.86);
  color: #7a5f48;
  font-size: 22rpx;
  border: 1rpx solid rgba(176, 125, 71, 0.12);
}

.minimal-logo {
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  box-shadow: 0 4rpx 14rpx rgba(19, 155, 215, 0.15), 0 0 0 3rpx rgba(255, 255, 255, 0.85);
}

.minimal-brand {
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 8rpx;
  color: #3a2a1c;
}

.minimal-button {
  width: 220rpx;
  height: 104rpx;
  border-radius: 34rpx 66rpx 42rpx 72rpx;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 40rpx rgba(76, 55, 30, 0.12);
}

.charge-btn {
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease, background 0.25s ease;
  position: relative;
  overflow: hidden;
}

.charge-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: radial-gradient(circle at 50% 50%, rgba(255, 200, 60, 0.5) 0%, rgba(255, 132, 35, 0) 70%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.charge-active {
  transform: scale(1.12);
  box-shadow: 0 24rpx 60rpx rgba(255, 132, 35, 0.35), 0 0 40rpx rgba(255, 187, 68, 0.25);
  background: linear-gradient(135deg, #ff8c23 0%, #ff6012 100%) !important;
}

.charge-active::before {
  opacity: 1;
  animation: chargePulse 0.6s ease-in-out infinite;
}

@keyframes chargePulse {
  0%, 100% { transform: scale(0.8); opacity: 0.5; }
  50% { transform: scale(1.2); opacity: 1; }
}

.charge-hint {
  font-size: 20rpx;
  color: #b35d23;
  animation: chargeHintBlink 0.5s ease-in-out infinite alternate;
}

@keyframes chargeHintBlink {
  0% { opacity: 0.5; }
  100% { opacity: 1; }
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 42rpx;
  padding: 0 6rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 18rpx;
}

.ongoing-card {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  background: linear-gradient(145deg, rgba(255, 250, 243, 0.97) 0%, rgba(248, 238, 226, 0.94) 100%);
  border-radius: 34rpx 84rpx 38rpx 72rpx;
}

.ongoing-theme:nth-child(odd) {
  background: linear-gradient(145deg, rgba(255, 247, 238, 0.98) 0%, rgba(248, 226, 205, 0.95) 100%);
}

.ongoing-theme:nth-child(even) {
  background: linear-gradient(145deg, rgba(250, 245, 236, 0.98) 0%, rgba(236, 227, 198, 0.94) 100%);
}

.accent-item {
  top: -18rpx;
  right: -6rpx;
  width: 120rpx;
  height: 120rpx;
  background: radial-gradient(circle, rgba(212, 149, 89, 0.18) 0%, rgba(212, 149, 89, 0) 72%);
}

.card-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tag-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-tag {
  padding: 8rpx 16rpx;
  border-radius: 18rpx 22rpx 18rpx 26rpx;
  background: rgba(223, 168, 108, 0.2);
  color: #87522f;
  font-size: 22rpx;
}

.card-mode {
  padding: 8rpx 16rpx;
  border-radius: 20rpx 24rpx 18rpx 22rpx;
  background: rgba(255, 248, 238, 0.72);
  color: #8c725e;
  font-size: 22rpx;
}

.card-arrow {
  font-size: 22rpx;
  color: #9a8977;
}

.card-title {
  display: block;
  margin-top: 22rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #2f2218;
}

.card-meta {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #766553;
}

.card-status {
  display: block;
  font-size: 24rpx;
  color: #b35d23;
}

.card-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 20rpx;
}

.card-count {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9a8977;
}

.avatar-stack {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.avatar-pill {
  min-width: 56rpx;
  height: 56rpx;
  padding: 0 12rpx;
  margin-left: -12rpx;
  border: 4rpx solid #fffaf3;
  border-radius: 20rpx 24rpx 18rpx 26rpx;
  background: #e8d2b8;
  color: #5d4127;
  font-size: 20rpx;
  line-height: 48rpx;
  text-align: center;
  box-sizing: border-box;
}

.home-login-hint-card {
  margin: 20rpx 32rpx;
  padding: 36rpx 28rpx;
  text-align: center;
}

.auth-close-row {
  margin-top: 20rpx;
  text-align: center;
}

.auth-close-text {
  font-size: 26rpx;
  color: #9a8977;
}

.browse-mode {
  padding: 20rpx 0;
}

.feature-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 24rpx;
}

.feature-card {
  padding: 32rpx 28rpx;
  border-radius: 32rpx 48rpx 36rpx 52rpx;
  background: linear-gradient(145deg, rgba(235, 248, 255, 0.92) 0%, rgba(255, 234, 213, 0.88) 100%);
  box-shadow: 0 8rpx 24rpx rgba(31, 110, 161, 0.08);
}

.feature-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.feature-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #2f2218;
  margin-bottom: 8rpx;
}

.feature-desc {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7a6856;
}

.browse-cta {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 48rpx;
  padding: 48rpx 28rpx 36rpx;
  border-radius: 36rpx 64rpx 40rpx 68rpx;
  background: linear-gradient(145deg, rgba(255, 248, 238, 0.96) 0%, rgba(255, 225, 195, 0.92) 100%);
  box-shadow: 0 16rpx 40rpx rgba(31, 111, 161, 0.12);
}

.ok-btn {
  display: flex;
  align-items: baseline;
  justify-content: center;
  padding: 12rpx 56rpx 20rpx;
  border-radius: 32rpx 56rpx 36rpx 64rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.7) 0%, rgba(255, 238, 218, 0.5) 100%);
  box-shadow: 0 6rpx 24rpx rgba(255, 125, 33, 0.1);
  position: relative;
  overflow: hidden;
}

.ok-btn::before {
  content: '';
  position: absolute;
  top: -40%;
  left: 10%;
  width: 80%;
  height: 60%;
  border-radius: 50%;
  background: radial-gradient(ellipse, rgba(255, 200, 80, 0.3) 0%, rgba(255, 200, 80, 0) 70%);
  pointer-events: none;
}

.ok-letter {
  display: inline-block;
  font-weight: 900;
  line-height: 1;
}

.ok-o {
  font-size: 80rpx;
  background: linear-gradient(160deg, #1198d4 0%, #0ec5e8 50%, #13b5f0 100%);
  -webkit-background-clip: text;
  color: transparent;
  margin-right: 4rpx;
  transform: rotate(-6deg) translateY(-4rpx);
  text-shadow: 0 4rpx 16rpx rgba(17, 152, 212, 0.2);
}

.ok-k {
  font-size: 72rpx;
  background: linear-gradient(160deg, #ff9d3a 0%, #ff7d21 50%, #ff5e14 100%);
  -webkit-background-clip: text;
  color: transparent;
  transform: rotate(4deg) translateY(6rpx);
  text-shadow: 0 4rpx 16rpx rgba(255, 125, 33, 0.2);
}

.ok-bang {
  display: inline-block;
  font-size: 96rpx;
  font-weight: 900;
  line-height: 1;
  background: linear-gradient(160deg, #ff7d21 0%, #ff4e10 100%);
  -webkit-background-clip: text;
  color: transparent;
  margin-left: 6rpx;
  transform: rotate(12deg) translateY(-8rpx);
  text-shadow: 0 4rpx 16rpx rgba(255, 78, 16, 0.2);
}

.cta-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #9a8977;
  letter-spacing: 4rpx;
}

/* ===== 旋天阵侧边抽屉 ===== */

.game-drawer-tab {
  position: fixed;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 18rpx 10rpx;
  background: linear-gradient(180deg, rgba(240, 160, 48, 0.92) 0%, rgba(232, 120, 40, 0.92) 100%);
  border-radius: 16rpx 0 0 16rpx;
  box-shadow: -4rpx 4rpx 20rpx rgba(232, 120, 40, 0.35);
  z-index: 999;
  animation: drawer-tab-pulse 3s ease-in-out infinite;
}

.game-drawer-tab-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1.3;
  letter-spacing: 2rpx;
  writing-mode: vertical-rl;
}

@keyframes drawer-tab-pulse {
  0%, 100% { box-shadow: -4rpx 4rpx 20rpx rgba(232, 120, 40, 0.35); }
  50% { box-shadow: -4rpx 4rpx 28rpx rgba(232, 120, 40, 0.55); }
}

.game-drawer-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  animation: mask-fade-in 0.2s ease-out;
}

@keyframes mask-fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

.game-drawer-panel {
  position: fixed;
  right: -400rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 320rpx;
  background: linear-gradient(165deg, rgba(255, 250, 243, 0.98) 0%, rgba(255, 235, 210, 0.96) 100%);
  border-radius: 28rpx 0 0 28rpx;
  box-shadow: -8rpx 8rpx 36rpx rgba(0, 0, 0, 0.15);
  z-index: 1001;
  transition: right 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}

.game-drawer-panel-open {
  right: 0;
}

.game-drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 16rpx;
}

.game-drawer-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2f2218;
}

.game-drawer-close {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.06);
  color: #8b735d;
  font-size: 22rpx;
}

.game-drawer-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 28rpx 32rpx;
  gap: 16rpx;
}

.game-drawer-cover {
  width: 260rpx;
  height: 260rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.game-drawer-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2f2218;
}

.game-drawer-desc {
  font-size: 22rpx;
  color: #8b735d;
}

.game-drawer-play-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f0a030, #e87828);
  box-shadow: 0 6rpx 20rpx rgba(232, 120, 40, 0.4);
  margin-top: 8rpx;
}

.game-drawer-play-btn:active {
  opacity: 0.85;
  transform: scale(0.96);
}

.game-drawer-play-text {
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}