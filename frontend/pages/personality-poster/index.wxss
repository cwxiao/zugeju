page {
  background: radial-gradient(circle at top, #17334f 0%, #10151f 48%, #28160d 100%);
}

.poster-page-shell {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.poster-stage {
  position: relative;
  min-height: calc(100vh - 48rpx);
  overflow: hidden;
}

.poster-glow {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(30rpx);
  opacity: 0.55;
}

.poster-glow-a {
  top: 40rpx;
  left: -80rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(26, 163, 232, 0.34);
}

.poster-glow-b {
  right: -90rpx;
  bottom: 180rpx;
  width: 340rpx;
  height: 340rpx;
  background: rgba(255, 139, 51, 0.3);
}

.poster-card {
  position: relative;
  min-height: calc(100vh - 48rpx);
  padding: 40rpx 34rpx;
  border-radius: 42rpx;
  box-sizing: border-box;
  background: linear-gradient(165deg, rgba(20, 32, 48, 0.96) 0%, rgba(33, 48, 69, 0.94) 42%, rgba(255, 136, 48, 0.9) 100%);
  color: #fff8f1;
  box-shadow: 0 30rpx 80rpx rgba(0, 0, 0, 0.24);
}

.poster-kicker,
.poster-score-label,
.poster-metric-label,
.poster-footnote,
.poster-section-title {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 248, 241, 0.72);
}

.poster-name,
.poster-title,
.poster-score,
.poster-metric-value,
.poster-animal {
  display: block;
  color: #fff8f1;
  font-weight: 700;
}

.poster-name {
  margin-top: 30rpx;
  font-size: 58rpx;
  line-height: 1;
}

.poster-title {
  margin-top: 12rpx;
  font-size: 40rpx;
}

.poster-desc,
.poster-quote-text {
  display: block;
  font-size: 25rpx;
  line-height: 1.8;
  color: rgba(255, 248, 241, 0.9);
}

.poster-desc {
  margin-top: 18rpx;
}

.poster-score-row,
.poster-footer,
.poster-dna-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.poster-score-row {
  margin-top: 34rpx;
}

.poster-score {
  font-size: 104rpx;
  line-height: 1;
}

.poster-beat-pill,
.poster-badge {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 241, 0.16);
  font-size: 22rpx;
  color: #fff8f1;
}

.poster-quote-box {
  position: relative;
  margin-top: 30rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 248, 241, 0.1);
}

.poster-quote-mark {
  position: absolute;
  top: 10rpx;
  left: 18rpx;
  font-size: 60rpx;
  line-height: 1;
  color: rgba(255, 248, 241, 0.26);
}

.poster-quote-text {
  padding-left: 18rpx;
}

.poster-metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 26rpx;
}

.poster-metric-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 248, 241, 0.1);
}

.poster-metric-value {
  font-size: 30rpx;
}

.poster-metric-label {
  margin-top: 8rpx;
}

.poster-dna-section {
  margin-top: 30rpx;
}

.poster-dna-row {
  margin-top: 16rpx;
}

.poster-dna-name {
  width: 110rpx;
  font-size: 24rpx;
  color: #fff8f1;
}

.poster-dna-track {
  flex: 1;
  height: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 241, 0.12);
  overflow: hidden;
}

.poster-dna-bar {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #29b7ff 0%, #ffd270 100%);
}

.poster-footer {
  margin-top: 34rpx;
  align-items: flex-end;
}

.poster-animal {
  font-size: 30rpx;
}

.poster-footnote {
  margin-top: 10rpx;
  max-width: 420rpx;
  line-height: 1.7;
}