<view class="page-shell">
  <image class="page-bg-img" src="/img/city-bg.png" mode="aspectFill" />
  <view class="detail-stage">
    <view class="detail-orb detail-orb-left"></view>
    <view class="detail-orb detail-orb-right"></view>
    <view class="detail-arc detail-arc-top"></view>
    <view class="detail-arc detail-arc-bottom"></view>
    <view class="detail-spark detail-spark-a"></view>
    <view class="detail-spark detail-spark-b"></view>

    <view class="summary-card detail-card hero-detail-card detail-card-sunrise">
      <image class="detail-decor-character" src="/img/ui-character.webp" mode="aspectFit" />
      <view class="detail-card-accent accent-hero"></view>
      <view class="detail-topline">
        <view class="tag-group">
          <text class="card-tag">{{detail.tag}}</text>
          <text class="card-mode">{{detail.mode}}</text>
        </view>
        <view class="detail-top-actions">
          <view wx:if="{{detail.isCreator && detail.rawStatus !== 'finished' && detail.rawStatus !== 'cancelled'}}" class="detail-edit-link" bindtap="goEdit">修改</view>
          <view wx:if="{{detail.isCreator && detail.rawStatus !== 'finished' && detail.rawStatus !== 'cancelled'}}" class="detail-cancel-link" bindtap="cancelActivity">取消</view>
          <text class="detail-count">{{detail.count}}</text>
        </view>
      </view>
      <text class="detail-title">{{detail.title}}</text>
      <text class="detail-subtitle">{{detail.status}}</text>
      <view class="detail-meta-strip">
        <view class="detail-meta-chip">{{detail.time}}</view>
        <view wx:if="{{detail.mode === '线下'}}" class="detail-meta-chip">{{detail.place}}</view>
        <view wx:if="{{detail.expenseModeLabel}}" class="detail-meta-chip">{{detail.expenseModeLabel}}</view>
      </view>

      <view wx:if="{{detail.rawStatus !== 'cancelled'}}" class="reaction-zone">
        <view class="reaction-bar">
          <block wx:for="{{reactions}}" wx:key="emoji">
            <view class="reaction-btn {{item.count > 0 ? 'reaction-used' : ''}}" data-emoji="{{item.emoji}}" data-label="{{item.label}}" catchtap="sendReaction">
              <text class="reaction-emoji">{{item.emoji}}</text>
              <text wx:if="{{item.count > 0}}" class="reaction-count">{{item.count}}</text>
            </view>
          </block>
        </view>
      </view>
      <view class="reaction-float-layer">
        <block wx:for="{{floatingReactions}}" wx:key="id">
          <view class="reaction-float-bubble" style="left:{{item.left}}%;animation-delay:{{item.delay}}ms">
            <text>{{item.emoji}}</text>
            <text class="float-label">{{item.label}}</text>
          </view>
        </block>
      </view>
        <view class="avatar-stack detail-avatar-stack">
          <block wx:for="{{detail.members}}" wx:key="id">
            <view class="avatar-pill avatar-image-pill" style="background: {{item.avatarUrl && !item.avatarError ? 'transparent' : (item.avatarBg || '#e8d2b8')}}; border-color: {{item.avatarUrl && !item.avatarError ? '#fffaf3' : (item.avatarBg || '#e8d2b8')}};">
              <image wx:if="{{item.avatarUrl && !item.avatarError}}" class="avatar-pill-image" src="{{item.avatarUrl}}" mode="aspectFill" binderror="onAvatarError" data-index="{{index}}" />
              <text wx:else style="color: {{item.avatarFg || '#5d4127'}};">{{item.shortName}}</text>
            </view>
          </block>
          <button class="avatar-pill avatar-plus-pill" open-type="share">
            <text class="avatar-plus-icon">+</text>
          </button>
        </view>
      <view wx:if="{{detail.canJoin}}" class="invite-action-row">
        <button class="invite-accept-button" loading="{{joining}}" bindtap="acceptInvite">接受邀请</button>
        <button class="invite-decline-button" bindtap="declineInvite">婉拒</button>
      </view>
      <view wx:if="{{detail.currentUserJoined && !detail.isCreator && detail.rawStatus !== 'finished' && detail.rawStatus !== 'cancelled'}}" class="invite-action-row-single">
        <button class="invite-decline-button invite-quit-button" bindtap="quitActivity">退出活动</button>
      </view>
      <view wx:if="{{detail.mode === '线下' && detail.currentUserJoined}}" class="detail-tool-row">
        <view class="detail-tool-link" bindtap="goBills">记账结算</view>
      </view>
    </view>

    <!--
    <view class="ad-slot-card">
      <text class="ad-slot-badge">广告位预留</text>
      <text class="ad-slot-title">详情页横幅广告</text>
      <text class="ad-slot-desc">活动详情和成员区之间预留广告位，后面可以接品牌投放或活动赞助位。</text>
      <text class="ad-slot-footnote">这个位置曝光稳定，但不会盖住分享和成员操作。</text>
    </view>
    -->

    <view class="summary-card detail-card info-card detail-card-clay-soft">
      <view class="detail-card-accent accent-info"></view>
      <view class="card-caption">到场的人</view>
      <view class="round-table">
        <view class="round-table-center">
          <text class="round-table-emoji">🔥</text>
          <text class="round-table-label">{{detail.members.length}}人围坐</text>
        </view>
        <block wx:for="{{roundTablePositions}}" wx:key="id">
          <view class="round-seat" style="left:{{item.x}};top:{{item.y}};">
            <view class="member-avatar member-avatar-frame" style="background: {{item.avatarBg || '#e8d2b8'}};">
              <image wx:if="{{item.avatarUrl && !item.avatarError}}" class="member-avatar-image" src="{{item.avatarUrl}}" mode="aspectFill" binderror="onRoundAvatarError" data-index="{{index}}" />
              <text wx:else style="color: {{item.avatarFg || '#5d4127'}};">{{item.shortName}}</text>
            </view>
            <text class="member-name">{{item.nickname}}</text>
          </view>
        </block>
        <button class="round-seat round-seat-invite" open-type="share">
          <view class="member-avatar member-avatar-plus">
            <text class="round-plus-icon">+</text>
          </view>
          <text class="member-name">邀请</text>
        </button>
      </view>
    </view>
  </view>
</view>