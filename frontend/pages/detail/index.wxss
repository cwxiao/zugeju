.detail-stage {
  position: relative;
  min-height: calc(100vh - 64rpx);
  overflow: hidden;
}

/* ===== 内联登录弹窗 ===== */

.auth-mask {
  position: absolute;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(34, 24, 17, 0.42);
  backdrop-filter: blur(16rpx);
}

.auth-dialog {
  width: 100%;
  padding: 42rpx 34rpx;
  border-radius: 40rpx 100rpx 44rpx 78rpx;
  background: linear-gradient(145deg, rgba(234, 248, 255, 0.98) 0%, rgba(255, 228, 196, 0.96) 100%);
  box-shadow: 0 28rpx 64rpx rgba(22, 72, 116, 0.2);
}

.auth-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(19, 155, 215, 0.18), 0 0 0 4rpx rgba(255, 255, 255, 0.9);
}

.auth-title {
  display: block;
  margin-top: 28rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #2f2218;
}

.auth-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #735d4b;
}

.auth-section-tip {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8b6c54;
}

.auth-subscribe-tip {
  margin-top: 18rpx;
  text-align: center;
}

.auth-action-area {
  margin-top: 32rpx;
}

.auth-step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.auth-step-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2479a4;
  margin-bottom: 16rpx;
}

.auth-step-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #c4702a;
  text-align: center;
}

.auth-agree-button {
  width: 100%;
  height: 96rpx;
  margin-top: 8rpx;
  padding: 0;
  border: none;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #1198d4 0%, #ff7d21 100%);
  color: #fff9f3;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 20rpx 38rpx rgba(31, 111, 161, 0.24);
  box-sizing: border-box;
  line-height: 96rpx;
}

.auth-agree-button::after {
  border: none;
}

.auth-nickname-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(56, 151, 197, 0.18);
}

.auth-nickname-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.auth-nickname-input {
  flex: 1;
  height: 72rpx;
  font-size: 30rpx;
  color: #2f2218;
  font-weight: 600;
}

.auth-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 32rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(249, 252, 255, 0.84);
  box-shadow: inset 0 0 0 1rpx rgba(32, 163, 225, 0.1);
}

.auth-preview-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  border: 4rpx solid #fffaf3;
  box-shadow: 0 8rpx 20rpx rgba(31, 110, 160, 0.14);
}

.auth-preview-nickname {
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #2f2218;
}

.auth-preview-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8b6c54;
}

.auth-confirm-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  margin-top: 22rpx;
  padding: 0 30rpx;
  border: none;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #1198d4 0%, #ff7d21 100%);
  color: #fff9f3;
  box-shadow: 0 20rpx 38rpx rgba(31, 111, 161, 0.24);
  font-size: 30rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.auth-confirm-button::after {
  border: none;
}

.auth-close-row {
  margin-top: 20rpx;
  text-align: center;
}

.auth-close-text {
  font-size: 26rpx;
  color: #9a8977;
}

.detail-orb {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(12rpx);
  opacity: 0.75;
}

.detail-orb-left {
  top: 20rpx;
  left: -90rpx;
  width: 270rpx;
  height: 270rpx;
  background: rgba(230, 121, 80, 0.22);
}

.detail-orb-right {
  top: 250rpx;
  right: -60rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(217, 183, 98, 0.2);
}

.detail-arc {
  position: absolute;
  height: 92rpx;
  border-radius: 999rpx;
  opacity: 0.56;
}

.detail-arc-top {
  top: 126rpx;
  left: -30rpx;
  width: 300rpx;
  transform: rotate(-14deg);
  background: linear-gradient(90deg, rgba(236, 176, 99, 0.18) 0%, rgba(229, 117, 74, 0.26) 100%);
}

.detail-arc-bottom {
  top: 880rpx;
  right: -50rpx;
  width: 290rpx;
  transform: rotate(18deg);
  background: linear-gradient(90deg, rgba(236, 197, 118, 0.14) 0%, rgba(200, 129, 80, 0.22) 100%);
}

.detail-spark {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border-radius: 7rpx;
  transform: rotate(16deg);
}

.detail-spark-a {
  top: 208rpx;
  right: 108rpx;
  background: rgba(226, 124, 73, 0.38);
}

.detail-spark-b {
  top: 1030rpx;
  left: 54rpx;
  background: rgba(214, 172, 82, 0.38);
}

.detail-card {
  position: relative;
  overflow: hidden;
  padding: 32rpx 28rpx;
  background: linear-gradient(145deg, rgba(255, 250, 243, 0.97) 0%, rgba(247, 236, 222, 0.92) 100%);
  backdrop-filter: blur(8rpx);
  border-radius: 36rpx 94rpx 40rpx 78rpx;
}

.detail-card-sunrise {
  background: linear-gradient(145deg, rgba(229, 245, 255, 0.98) 0%, rgba(255, 222, 190, 0.94) 100%);
  box-shadow: 0 24rpx 54rpx rgba(32, 98, 150, 0.16);
}

.detail-card-sand {
  background: linear-gradient(145deg, rgba(241, 250, 255, 0.98) 0%, rgba(255, 236, 214, 0.95) 100%);
}

.detail-card-clay-soft {
  background: linear-gradient(145deg, rgba(244, 251, 255, 0.98) 0%, rgba(255, 231, 210, 0.95) 100%);
}

.detail-card-sand-deep {
  background: linear-gradient(145deg, rgba(234, 247, 255, 0.98) 0%, rgba(255, 220, 188, 0.95) 100%);
}

.detail-card-plain {
  background: linear-gradient(145deg, rgba(248, 252, 255, 0.98) 0%, rgba(255, 239, 224, 0.95) 100%);
}

.detail-card-accent {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.accent-hero {
  top: -22rpx;
  right: 18rpx;
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(36, 186, 244, 0.22) 0%, rgba(255, 128, 31, 0.18) 44%, rgba(228, 150, 74, 0) 72%);
}

.accent-info {
  top: -18rpx;
  right: -8rpx;
  width: 120rpx;
  height: 120rpx;
  background: radial-gradient(circle, rgba(209, 142, 84, 0.14) 0%, rgba(209, 142, 84, 0) 72%);
}

.hero-detail-card {
  background: linear-gradient(135deg, rgba(255, 246, 234, 0.98) 0%, rgba(242, 223, 199, 0.92) 100%);
  border-radius: 38rpx 112rpx 44rpx 84rpx;
  position: relative;
}

.detail-decor-character {
  position: absolute;
  top: -8rpx;
  right: 10rpx;
  width: 150rpx;
  height: 150rpx;
  opacity: 0.4;
  transform: rotate(6deg);
  pointer-events: none;
  z-index: 1;
}

.info-card {
  margin-top: 18rpx;
  overflow: visible;
  padding-bottom: 48rpx;
}

.detail-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-top-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.detail-edit-link {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(33, 186, 244, 0.12);
  color: #0b7aa1;
  font-size: 22rpx;
}

.detail-cancel-link {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 124, 33, 0.14);
  color: #b85a1d;
  font-size: 22rpx;
}

.tag-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-tag {
  padding: 8rpx 16rpx;
  border-radius: 18rpx 22rpx 18rpx 26rpx;
  background: rgba(255, 136, 43, 0.18);
  color: #ae5816;
  font-size: 22rpx;
}

.card-mode {
  padding: 8rpx 16rpx;
  border-radius: 20rpx 24rpx 18rpx 22rpx;
  background: rgba(30, 183, 244, 0.12);
  color: #177ca0;
  font-size: 22rpx;
}

.detail-count {
  font-size: 24rpx;
  color: #8b7867;
}

.detail-title {
  display: block;
  margin-top: 24rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #2f2218;
}

.detail-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #b35d23;
}

.detail-meta-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.detail-meta-chip {
  padding: 10rpx 18rpx;
  border-radius: 18rpx 24rpx 18rpx 24rpx;
  background: rgba(255, 250, 243, 0.72);
  color: #6f5e4e;
  font-size: 22rpx;
}

.detail-meta-chip-location {
  background: rgba(255, 250, 243, 0.72);
  color: #0b7aa1;
  padding-right: 36rpx;
  position: relative;
}

.detail-meta-chip-location::after {
  content: '▸';
  position: absolute;
  right: 14rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 18rpx;
  color: #0b7aa1;
}

.detail-meta-chip-location:active {
  background: rgba(33, 186, 244, 0.12);
}

.reaction-zone {
  margin-top: 20rpx;
  position: relative;
}

.reaction-bar {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.reaction-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 243, 0.6);
  border: 1rpx solid rgba(176, 125, 71, 0.1);
  transition: transform 0.15s ease, background 0.2s ease;
}

.reaction-btn:active {
  transform: scale(0.9);
}

.reaction-used {
  background: linear-gradient(135deg, rgba(255, 187, 68, 0.18) 0%, rgba(255, 132, 35, 0.14) 100%);
  border-color: rgba(255, 132, 35, 0.2);
}

.reaction-emoji {
  font-size: 28rpx;
}

.reaction-count {
  font-size: 20rpx;
  color: #b35d23;
  font-weight: 600;
}

.reaction-float-layer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 200rpx;
  pointer-events: none;
  overflow: hidden;
}

.reaction-float-bubble {
  position: absolute;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 36rpx;
  animation: reactionFloat 1s ease-out forwards;
}

.float-label {
  font-size: 18rpx;
  color: #b35d23;
  font-weight: 600;
}

@keyframes reactionFloat {
  0% {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
  60% {
    transform: translateY(-120rpx) scale(1.3);
    opacity: 0.9;
  }
  100% {
    transform: translateY(-200rpx) scale(0.8);
    opacity: 0;
  }
}

.detail-avatar-stack {
  margin-top: 24rpx;
}

/* ===== 邀请操作按钮区 ===== */

.invite-action-row {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 16rpx;
  margin-top: 28rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(176, 125, 71, 0.12);
}

.invite-action-row-single {
  display: flex;
  justify-content: center;
  margin-top: 28rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(176, 125, 71, 0.12);
}

.invite-action-row-single .invite-quit-button {
  width: 60%;
  max-width: 400rpx;
}

.invite-accept-button,
.invite-decline-button {
  flex: 1;
  height: 84rpx;
  border: none;
  border-radius: 24rpx 32rpx 22rpx 30rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 84rpx;
  text-align: center;
  box-sizing: border-box;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.invite-accept-button {
  background: #c96f2d;
  color: #fffaf3;
}

.invite-decline-button {
  background: rgba(255, 250, 243, 0.76);
  color: #7a5634;
}

.invite-accept-button::after,
.invite-decline-button::after {
  border: none;
}

.detail-tool-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 22rpx;
}

.detail-tool-link {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 246, 0.78);
  color: #7a5634;
  font-size: 24rpx;
}

.avatar-stack {
  display: flex;
  align-items: center;
}

.avatar-pill {
  min-width: 60rpx;
  height: 60rpx;
  padding: 0 14rpx;
  margin-left: -12rpx;
  border: 4rpx solid #fffaf3;
  border-radius: 20rpx 24rpx 18rpx 26rpx;
  background: #e8d2b8;
  color: #5d4127;
  font-size: 20rpx;
  line-height: 52rpx;
  text-align: center;
  box-sizing: border-box;
}

.avatar-image-pill {
  width: 60rpx;
  min-width: 60rpx;
  padding: 0;
  overflow: hidden;
  border-radius: 22rpx;
}

.avatar-pill-image {
  width: 100%;
  height: 100%;
  display: block;
}

button.avatar-plus-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  margin: 0 0 0 8rpx;
  padding: 0;
  border: none;
  border-radius: 50%;
  background: linear-gradient(145deg, #f0a030, #e87828);
  color: #fff;
  font-size: 34rpx;
  line-height: 1;
  box-sizing: border-box;
  box-shadow: 0 4rpx 16rpx rgba(232, 120, 40, 0.35);
  animation: plus-pulse 2s ease-in-out infinite;
  flex-shrink: 0;
}

button.avatar-plus-pill::after {
  border: none;
}

.avatar-plus-icon {
  font-size: 34rpx;
  line-height: 1;
  color: #fff;
  font-weight: 700;
}

.avatar-plus-pill::after,
.member-invite-card::after {
  border: none;
}

.avatar-pill:first-child {
  margin-left: 0;
}

.card-caption {
  font-size: 24rpx;
  color: #9a8977;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #f0e6d8;
}

.first-row {
  margin-top: 8rpx;
}

.detail-label {
  font-size: 24rpx;
  color: #8a7866;
}

.detail-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #2f2218;
}

.detail-note {
  padding-top: 26rpx;
}

.first-note {
  padding-top: 14rpx;
}

.detail-note-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.7;
  color: #2f2218;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx 28rpx 20rpx 26rpx;
  background: #e8d2b8;
  color: #5d4127;
  font-size: 24rpx;
  line-height: 72rpx;
  text-align: center;
}

.member-avatar-frame {
  overflow: hidden;
}

.member-avatar-image {
  width: 100%;
  height: 100%;
  display: block;
}

.member-avatar-plus {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(145deg, #f0a030, #e87828);
  color: #fff;
  font-size: 42rpx;
  line-height: 72rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(232, 120, 40, 0.35);
  animation: plus-pulse 2s ease-in-out infinite;
  overflow: visible;
}

.round-plus-icon {
  font-size: 42rpx;
  line-height: 72rpx;
  color: #fff;
  font-weight: 700;
}

@keyframes plus-pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 4rpx 16rpx rgba(232, 120, 40, 0.35);
  }
  50% {
    transform: scale(1.12);
    box-shadow: 0 6rpx 24rpx rgba(232, 120, 40, 0.5);
  }
}

/* ===== 成员列表布局 ===== */

.member-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 24rpx;
}

.member-list-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 120rpx;
  padding: 16rpx 0;
  border-radius: 20rpx;
  background: transparent;
}

.member-list-invite {
  border: none;
  background: transparent;
  line-height: normal;
  padding: 16rpx 0;
  margin: 0;
}

button.member-list-invite::after {
  border: none;
}

.member-name {
  font-size: 22rpx;
  color: #5f4d3d;
}

.checklist-wrap {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.check-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.check-dot {
  width: 16rpx;
  height: 16rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: #c96f2d;
  flex-shrink: 0;
}

.check-text {
  font-size: 26rpx;
  line-height: 1.7;
  color: #2f2218;
}