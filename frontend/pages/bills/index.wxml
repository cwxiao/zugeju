<view class="page-shell bill-page-shell">
  <image class="page-bg-img" src="/img/city-bg.png" mode="aspectFill" />
  <view wx:if="{{!activityId}}" class="bill-card bill-shell bill-empty-card">
    <text class="bill-empty-badge">记账结算</text>
    <view class="section-title">先从具体活动进入账单</view>
    <text class="bill-meta">账单跟着活动走，可从活动档案进入。</text>
    <button class="primary-button bill-empty-button" bindtap="goActivities">去活动档案</button>
  </view>

  <view wx:elif="{{summary}}" class="bill-list bill-shell">
    <view class="bill-card bill-item bill-summary-card receipt-card">
      <image class="bill-decor-beer" src="/img/ui-beer-skewer.webp" mode="aspectFit" />
      <view class="receipt-header">
        <text class="receipt-label">— 来整小票 —</text>
      </view>
      <view class="bill-hero-topline">
        <view>
          <text class="bill-eyebrow">我的账单</text>
          <view class="section-title bill-hero-title">{{summary.activityTitle}}</view>
        </view>
        <view class="bill-chip-row">
          <view class="bill-chip">{{summary.expenseModeLabel}}</view>
          <view class="bill-chip">{{summary.statusLabel}}</view>
        </view>
      </view>
      <text class="bill-total receipt-total">{{summary.totalAmountText}}</text>
      <text class="bill-meta">{{summary.settlementSummaryText}}</text>
      <view class="receipt-divider"></view>
      <view class="bill-metric-grid">
        <view class="bill-metric-card receipt-metric">
          <text class="bill-metric-label">消费笔数</text>
          <text class="bill-metric-value">{{summary.recordCount}} 笔</text>
        </view>
        <view class="bill-metric-card receipt-metric">
          <text class="bill-metric-label">到场人数</text>
          <text class="bill-metric-value">{{summary.participantCount}} 人</text>
        </view>
        <view class="bill-metric-card bill-metric-card-wide receipt-metric">
          <text class="bill-metric-label">人均参考</text>
          <text class="bill-metric-value">{{summary.perHeadAmountText}}</text>
        </view>
      </view>
      <text class="bill-note-text">{{summary.settlementNote}}</text>
      <view wx:if="{{summary.activityStatus === 'finished'}}" class="receipt-stamp">
        <text>已结清</text>
      </view>
      <view class="receipt-tear"></view>
    </view>

    <!-- 记一笔消费 —— 发起人可添加，且支持选付款人 -->
    <view wx:if="{{summary.creatorView && summary.canAddExpense}}" class="bill-card bill-item bill-compose-card">
      <text class="bill-title">记一笔消费</text>
      <text class="bill-helper">选择消费项目，填入金额即可。</text>

      <!-- 消费项目卡片选择 -->
      <view class="bill-expense-cats">
        <block wx:for="{{expenseCategories}}" wx:key="label">
          <view class="bill-expense-cat">
            <text class="bill-expense-cat-label">{{item.label}}</text>
            <view class="bill-expense-chips">
              <view wx:for="{{item.items}}" wx:for-item="name" wx:key="*this"
                class="bill-expense-chip {{itemName === name ? 'bill-expense-chip-active' : ''}}"
                bindtap="chooseExpenseItem" data-name="{{name}}">
                {{name}}
              </view>
            </view>
          </view>
        </block>
      </view>

      <view class="bill-selected-item" wx:if="{{itemName}}">
        <text class="bill-selected-label">已选：</text>
        <text class="bill-selected-name">{{itemName}}</text>
      </view>

      <picker mode="selector" range="{{amountOptions}}" value="{{amountIndex}}" bindchange="onAmountChange">
        <view class="bill-picker-box {{amountIndex >= 0 ? 'bill-picker-active' : ''}}">
          {{amountIndex >= 0 ? amountOptions[amountIndex] + ' 元' : '选择金额'}}
        </view>
      </picker>
      <!-- 付款人选择 -->
      <view class="bill-payer-row">
        <text class="bill-payer-label">付款人</text>
        <picker mode="selector" range="{{payerOptions}}" range-key="nickname" value="{{payerIndex}}" bindchange="onPayerChange">
          <view class="bill-payer-picker">
            <text>{{payerOptions[payerIndex].nickname}}</text>
            <text class="bill-payer-arrow">▸</text>
          </view>
        </picker>
      </view>
      <button class="primary-button bill-submit-button" bindtap="submitExpense">记上去</button>
    </view>

    <!-- 消费记录 —— 所有成员可见，左滑可删除/编辑（仅发起人） -->
    <view class="bill-card bill-item bill-section-card" bindtap="closeSwipe">
      <view class="bill-section-head">
        <text class="bill-title">消费记录</text>
        <text class="bill-count-pill">{{summary.recordCount}} 笔</text>
      </view>
      <view wx:if="{{summary.expenseItems.length}}" class="bill-record-list">
        <block wx:for="{{summary.expenseItems}}" wx:key="id">
          <view class="bill-swipe-wrap">
            <!-- 操作按钮（露出层） -->
            <view wx:if="{{summary.creatorView && summary.canAddExpense}}" class="bill-swipe-actions">
              <view class="bill-swipe-btn bill-swipe-edit" catchtap="onEditExpense" data-index="{{index}}">编辑</view>
              <view class="bill-swipe-btn bill-swipe-delete" catchtap="onDeleteExpense" data-index="{{index}}">删除</view>
            </view>
            <!-- 消费行（滑动层） -->
            <view class="bill-swipe-content {{swipeIndex === index ? 'bill-swipe-open' : ''}}"
                  bindtouchstart="onTouchStart" bindtouchend="onTouchEnd" bindtouchmove="onTouchMove" data-index="{{index}}">
              <view class="bill-record-row">
                <view>
                  <text class="bill-record-title">{{item.itemName}}</text>
                  <text class="bill-record-meta">{{item.payerNickname}} 付款</text>
                </view>
                <text class="bill-record-amount">{{item.amountText}}</text>
              </view>
            </view>
          </view>
        </block>
      </view>
      <text wx:else class="bill-meta">还没记消费项。</text>
    </view>

    <!-- 每人收支明细 —— 所有成员可见 -->
    <view wx:if="{{summary.memberBalances.length}}" class="bill-card bill-item bill-section-card">
      <view class="bill-section-head">
        <text class="bill-title">每人收支</text>
      </view>
      <view class="bill-record-list">
        <block wx:for="{{summary.memberBalances}}" wx:key="userId">
          <view class="bill-record-row">
            <view>
              <text class="bill-record-title">{{item.nickname}}</text>
              <text class="bill-record-meta">已付 {{item.paidText}} · 应摊 {{item.shareText}}</text>
            </view>
            <text class="bill-record-amount {{item.balanceFen > 0 ? 'bill-record-amount-positive' : item.balanceFen < 0 ? 'bill-record-amount-strong' : ''}}">{{item.balanceText}}</text>
          </view>
        </block>
      </view>
    </view>

    <!-- 转账指令 —— 所有成员可见 -->
    <view wx:if="{{summary.transferItems.length}}" class="bill-card bill-item bill-section-card">
      <view class="bill-section-head">
        <text class="bill-title">转账安排</text>
        <text class="bill-count-pill">{{summary.transferItems.length}} 笔</text>
      </view>
      <view class="bill-record-list">
        <block wx:for="{{summary.transferItems}}" wx:key="index">
          <view class="bill-transfer-row">
            <view class="bill-transfer-flow">
              <text class="bill-transfer-name">{{item.fromNickname}}</text>
              <text class="bill-transfer-arrow">转给</text>
              <text class="bill-transfer-name">{{item.toNickname}}</text>
            </view>
            <text class="bill-record-amount bill-record-amount-strong">{{item.amountText}}</text>
          </view>
        </block>
      </view>
    </view>

    <!-- 旧版结算结果（兼容，仅当无转账指令时显示） -->
    <view wx:if="{{!summary.transferItems.length && summary.settlementItems.length}}" class="bill-card bill-item bill-section-card">
      <view class="bill-section-head">
        <text class="bill-title">结算结果</text>
        <text class="bill-count-pill">待转 {{summary.settlementPendingCount}} 人</text>
      </view>
      <view class="bill-record-list">
        <block wx:for="{{summary.settlementItems}}" wx:key="userId">
          <view class="bill-record-row">
            <view>
              <text class="bill-record-title">{{item.nickname}}</text>
              <text class="bill-record-meta">{{item.roleLabel}}</text>
            </view>
            <text class="bill-record-amount {{item.amountFen > 0 ? 'bill-record-amount-strong' : ''}}">{{item.amountText}}</text>
          </view>
        </block>
      </view>
    </view>

    <view wx:if="{{summary.creatorView && summary.canFinish}}" class="bill-card bill-item bill-action-card">
      <text class="bill-title">结束活动并结算</text>
      <text class="bill-helper">确认后按到场人数出最终结算。</text>
      <view class="bill-action-wrap">
        <button class="primary-button bill-finish-button" bindtap="finishActivity">结束活动并结算</button>
      </view>
    </view>
  </view>

  <!-- 编辑消费弹窗 -->
  <view wx:if="{{editVisible}}" class="bill-modal-mask" bindtap="closeEditModal">
    <view class="bill-modal" catchtap="">
      <text class="bill-modal-title">编辑消费</text>

      <!-- 消费项目卡片选择 -->
      <scroll-view scroll-y class="bill-edit-scroll">
        <view class="bill-expense-cats bill-edit-cats">
          <block wx:for="{{expenseCategories}}" wx:key="label">
            <view class="bill-expense-cat">
              <text class="bill-expense-cat-label">{{item.label}}</text>
              <view class="bill-expense-chips">
                <view wx:for="{{item.items}}" wx:for-item="name" wx:key="*this"
                  class="bill-expense-chip {{editItemName === name ? 'bill-expense-chip-active' : ''}}"
                  bindtap="chooseEditExpenseItem" data-name="{{name}}">
                  {{name}}
                </view>
              </view>
            </view>
          </block>
        </view>
      </scroll-view>

      <view class="bill-selected-item" wx:if="{{editItemName}}">
        <text class="bill-selected-label">已选：</text>
        <text class="bill-selected-name">{{editItemName}}</text>
      </view>

      <picker mode="selector" range="{{amountOptions}}" value="{{editAmountIndex}}" bindchange="onEditAmountChange">
        <view class="bill-picker-box {{editAmountIndex >= 0 ? 'bill-picker-active' : ''}}">
          {{editAmountIndex >= 0 ? amountOptions[editAmountIndex] + ' 元' : '选择金额'}}
        </view>
      </picker>
      <!-- 付款人选择 -->
      <view class="bill-payer-row">
        <text class="bill-payer-label">付款人</text>
        <picker mode="selector" range="{{editPayerOptions}}" range-key="nickname" value="{{editPayerIndex}}" bindchange="onEditPayerChange">
          <view class="bill-payer-picker">
            <text>{{editPayerOptions[editPayerIndex].nickname}}</text>
            <text class="bill-payer-arrow">▸</text>
          </view>
        </picker>
      </view>
      <view class="bill-modal-actions">
        <button class="bill-modal-cancel" bindtap="closeEditModal">取消</button>
        <button class="primary-button bill-modal-confirm" bindtap="confirmEdit">保存</button>
      </view>
    </view>
  </view>
</view>
