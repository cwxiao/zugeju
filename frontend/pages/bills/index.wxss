.bill-page-shell {
  padding-top: 24rpx;
}

.bill-shell,
.bill-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.bill-item {
  padding: 30rpx;
  background: rgba(255, 252, 247, 0.96);
}

.bill-empty-card {
  padding: 36rpx 32rpx;
}

.bill-empty-badge,
.bill-eyebrow,
.bill-metric-label,
.bill-helper {
  display: block;
  font-size: 22rpx;
  color: #8b735d;
}

.bill-empty-button {
  margin-top: 28rpx;
}

.bill-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2f2218;
}

.bill-meta,
.bill-note-text {
  display: block;
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: #6b5e4f;
}

.bill-summary-card {
  background: linear-gradient(145deg, rgba(237, 248, 255, 0.98) 0%, rgba(255, 237, 215, 0.96) 100%);
  position: relative;
  overflow: hidden;
}

.receipt-card {
  background: linear-gradient(180deg, #fffdf8 0%, #fef9f0 100%);
  border: 2rpx dashed rgba(176, 125, 71, 0.25);
  padding-bottom: 40rpx;
}

.receipt-header {
  text-align: center;
  margin-bottom: 20rpx;
}

.receipt-label {
  font-size: 24rpx;
  color: #a08060;
  letter-spacing: 8rpx;
}

.receipt-total {
  font-family: "Courier New", "Menlo", monospace;
  letter-spacing: 2rpx;
}

.receipt-divider {
  margin: 20rpx 0;
  border-top: 2rpx dashed rgba(176, 125, 71, 0.2);
}

.receipt-metric {
  border-radius: 0;
  background: transparent;
  padding: 16rpx 0;
  border-bottom: 1rpx dotted rgba(176, 125, 71, 0.15);
}

.receipt-metric .bill-metric-value {
  font-family: "Courier New", "Menlo", monospace;
}

.receipt-stamp {
  position: absolute;
  top: 50%;
  right: 30rpx;
  transform: translateY(-50%) rotate(-18deg);
  padding: 12rpx 28rpx;
  border: 4rpx solid rgba(200, 50, 30, 0.6);
  border-radius: 12rpx;
  color: rgba(200, 50, 30, 0.6);
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  pointer-events: none;
}

.receipt-tear {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 16rpx;
  background: repeating-linear-gradient(
    90deg,
    transparent 0rpx,
    transparent 16rpx,
    rgba(176, 125, 71, 0.12) 16rpx,
    rgba(176, 125, 71, 0.12) 18rpx
  );
}

.bill-decor-beer {
  position: absolute;
  bottom: 10rpx;
  right: 16rpx;
  width: 130rpx;
  height: 130rpx;
  opacity: 0.5;
  transform: rotate(-6deg);
  pointer-events: none;
}

.bill-hero-topline,
.bill-section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.bill-hero-title {
  margin: 10rpx 0 0;
}

.bill-chip-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 12rpx;
}

.bill-chip,
.bill-count-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 246, 0.78);
  color: #7c6551;
  font-size: 22rpx;
}

.bill-total {
  display: block;
  margin-top: 24rpx;
  font-size: 54rpx;
  line-height: 1.15;
  font-weight: 700;
  color: #2f2218;
}

.bill-metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 22rpx;
}

.bill-metric-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 251, 246, 0.72);
}

.bill-metric-card-wide {
  grid-column: span 2;
}

.bill-metric-value {
  display: block;
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #2f2218;
}

.bill-note-text {
  margin-top: 18rpx;
}

.bill-compose-card,
.bill-section-card,
.bill-action-card {
  box-shadow: 0 18rpx 40rpx rgba(38, 95, 145, 0.08);
}

.bill-helper {
  margin-top: 12rpx;
}

.bill-picker-box {
  display: flex;
  align-items: center;
  width: 100%;
  height: 90rpx;
  margin-top: 18rpx;
  padding: 0 26rpx;
  box-sizing: border-box;
  border-radius: 26rpx;
  background: rgba(255, 251, 246, 0.88);
  border: 1rpx solid rgba(176, 125, 71, 0.14);
  color: #b07d47;
  font-size: 26rpx;
}

/* ===== 金额手动输入 ===== */

.bill-amount-section {
  margin-top: 18rpx;
}

.bill-amount-label {
  font-size: 24rpx;
  color: #8b735d;
  margin-bottom: 10rpx;
  font-weight: 600;
}

.bill-amount-input {
  width: 100%;
  height: 90rpx;
  padding: 0 26rpx;
  box-sizing: border-box;
  border-radius: 26rpx;
  background: rgba(255, 251, 246, 0.88);
  border: 1rpx solid rgba(176, 125, 71, 0.14);
  color: #2e241b;
  font-size: 32rpx;
  font-weight: 600;
}

.bill-amount-active {
  border-color: rgba(56, 151, 197, 0.3);
  background: rgba(255, 251, 246, 1);
}

.bill-quick-amounts {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.bill-quick-chip {
  min-width: 80rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 246, 0.78);
  border: 1rpx solid rgba(176, 125, 71, 0.14);
  color: #5d4e3f;
  font-size: 24rpx;
  font-weight: 500;
}

.bill-picker-active {
  color: #2e241b;
  background: rgba(255, 251, 246, 1);
}

.bill-submit-button,
.bill-finish-button {
  margin-top: 24rpx;
  height: 96rpx;
}

/* ===== 付款人选择 ===== */

.bill-payer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  padding: 0 8rpx;
}

.bill-payer-label {
  font-size: 26rpx;
  color: #8b735d;
}

.bill-payer-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 251, 246, 0.88);
  border: 1rpx solid rgba(176, 125, 71, 0.14);
  font-size: 26rpx;
  color: #2f2218;
}

.bill-payer-arrow {
  font-size: 22rpx;
  color: #8b735d;
}

/* ===== 消费记录列表 ===== */

.bill-record-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 18rpx;
}

.bill-record-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx dotted rgba(176, 125, 71, 0.18);
}

.bill-record-title {
  display: block;
  font-size: 28rpx;
  color: #2f2218;
}

.bill-record-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8d7c69;
}

.bill-record-amount {
  font-size: 28rpx;
  color: #6b5e4f;
  font-family: "Courier New", "Menlo", monospace;
}

.bill-record-amount-strong {
  color: #b86122;
  font-weight: 700;
}

.bill-record-amount-positive {
  color: #2a9d5c;
  font-weight: 700;
}

.bill-action-wrap {
  margin-top: 20rpx;
}

/* ===== 左滑删除/编辑 ===== */

.bill-swipe-wrap {
  position: relative;
  overflow: hidden;
}

.bill-swipe-actions {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: stretch;
  z-index: 1;
}

.bill-swipe-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

.bill-swipe-edit {
  background: #f0a030;
}

.bill-swipe-delete {
  background: #e74c3c;
}

.bill-swipe-content {
  position: relative;
  z-index: 2;
  background: rgba(255, 252, 247, 0.96);
  transition: transform 0.25s ease;
}

.bill-swipe-open {
  transform: translateX(-240rpx);
}

/* ===== 转账指令行 ===== */

.bill-transfer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx dotted rgba(176, 125, 71, 0.18);
}

.bill-transfer-flow {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.bill-transfer-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f2218;
}

.bill-transfer-arrow {
  font-size: 24rpx;
  color: #8b735d;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(176, 125, 71, 0.1);
}

/* ===== 编辑弹窗 ===== */

.bill-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bill-modal {
  width: 85%;
  max-width: 600rpx;
  background: #fffdf8;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.bill-modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #2f2218;
  text-align: center;
  margin-bottom: 24rpx;
}

.bill-modal-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 30rpx;
}

.bill-modal-cancel {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  color: #8b735d;
  background: rgba(255, 251, 246, 0.88);
  border-radius: 24rpx;
  border: none;
}

.bill-modal-confirm {
  flex: 1;
  height: 88rpx;
  margin-top: 0;
}

/* ===== 消费项目搜索选择 ===== */

.bill-expense-search-section {
  margin-top: 18rpx;
}

.bill-expense-scroll {
  max-height: 320rpx;
  margin-bottom: 8rpx;
}

.bill-search-bar {
  display: flex;
  align-items: center;
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 251, 246, 0.88);
  border: 1rpx solid rgba(176, 125, 71, 0.14);
  box-sizing: border-box;
  gap: 10rpx;
}

.bill-search-bar-sm {
  height: 68rpx;
}

.bill-search-icon {
  font-size: 26rpx;
  flex-shrink: 0;
}

.bill-search-input {
  flex: 1;
  height: 100%;
  color: #2e241b;
  font-size: 26rpx;
}

.bill-search-clear {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(176, 125, 71, 0.12);
  color: #8b735d;
  font-size: 22rpx;
  flex-shrink: 0;
}

.bill-search-results {
  margin-top: 14rpx;
}

.bill-search-hint {
  display: block;
  text-align: center;
  padding: 30rpx 0;
  color: #b0a092;
  font-size: 24rpx;
}

.bill-search-chip {
  min-width: 100rpx;
  text-align: center;
}

.bill-expense-cats {
  margin-top: 18rpx;
}

.bill-expense-cat {
  margin-bottom: 16rpx;
}

.bill-expense-cat-label {
  display: block;
  font-size: 22rpx;
  color: #8b735d;
  margin-bottom: 10rpx;
  font-weight: 600;
}

.bill-expense-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.bill-expense-chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 246, 0.78);
  border: 1rpx solid rgba(176, 125, 71, 0.14);
  color: #5d4e3f;
  font-size: 24rpx;
  transition: all 0.15s ease;
}

.bill-expense-chip:active {
  transform: scale(0.95);
  opacity: 0.85;
}

.bill-expense-chip-active {
  background: linear-gradient(135deg, rgba(40, 182, 241, 0.16) 0%, rgba(255, 142, 45, 0.22) 100%);
  border-color: rgba(56, 151, 197, 0.25);
  color: #2e241b;
  font-weight: 600;
}

.bill-selected-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 14rpx;
  padding: 14rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 142, 45, 0.08);
}

.bill-selected-label {
  font-size: 22rpx;
  color: #8b735d;
}

.bill-selected-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #b86122;
}

/* ===== 编辑弹窗内消费卡片 ===== */

.bill-edit-scroll {
  max-height: 360rpx;
  margin-bottom: 12rpx;
}

.bill-edit-cats .bill-expense-cat {
  margin-bottom: 12rpx;
}
