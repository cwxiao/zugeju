<view class="page-shell">
  <view class="create-stage">
    <view class="create-orb create-orb-left"></view>
    <view class="create-orb create-orb-right"></view>
    <view class="create-wave create-wave-top"></view>
    <view class="create-wave create-wave-bottom"></view>
    <view class="create-dot create-dot-a"></view>
    <view class="create-dot create-dot-b"></view>

    <view class="form-card create-card create-header-card create-card-sunrise">
      <view class="create-card-accent accent-header"></view>
      <view class="create-header-top">
        <view>
          <view class="section-title">{{pageTitle}}</view>
        </view>
        <view class="header-badge">{{editingId ? '编辑中' : '草稿'}}</view>
      </view>

      <view class="summary-strip">
        <view class="summary-chip">{{form.date || '日期待定'}}</view>
        <view class="summary-chip">{{form.time || '时间待定'}}</view>
        <view class="summary-chip strong-chip">{{modes[modeIndex]}}</view>
      </view>

      <view class="topic-panel">
        <view class="field-block first-field compact-header-field">
          <text class="field-label">活动主题</text>
          <view class="header-input-shell">
            <input
              class="header-input-control"
              placeholder="比如：这次先整一个"
              placeholder-class="input-placeholder"
              value="{{form.title}}"
              bindinput="onTitleInput"
              maxlength="30"
            />
          </view>
        </view>

        <view class="type-selector-block">
          <text class="field-label">活动类型</text>
          <view class="type-chip-row">
            <block wx:for="{{activityTypes}}" wx:key="code">
              <view
                class="type-chip {{activityTypeIndex === index ? 'type-chip-active' : ''}}"
                data-index="{{index}}"
                bindtap="chooseActivityType"
              >{{item.name}}</view>
            </block>
          </view>
        </view>
      </view>
    </view>

    <view class="form-card create-card input-card create-card-sand">
      <view class="create-card-accent accent-input"></view>
      <view class="card-caption">时间</view>
      <view class="field-grid">
        <view class="field-block compact-field">
          <text class="field-label">日期</text>
          <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
            <view class="field-box {{form.date ? 'field-value' : ''}}">{{form.date || '选择日期'}}</view>
          </picker>
        </view>
        <view class="field-block compact-field">
          <text class="field-label">时间</text>
          <picker mode="time" value="{{form.time}}" bindchange="onTimeChange">
            <view class="field-box {{form.time ? 'field-value' : ''}}">{{form.time || '选择时间'}}</view>
          </picker>
        </view>
      </view>
    </view>

    <view class="form-card create-card input-card create-card-clay-soft">
      <view class="create-card-accent accent-input"></view>
      <view class="card-caption">方式和地点</view>
      <view class="field-block first-field">
        <text class="field-label">方式</text>
        <picker mode="selector" range="{{modes}}" value="{{modeIndex}}" bindchange="onModeChange">
          <view class="field-box field-value">{{modes[modeIndex]}}</view>
        </picker>
      </view>
      <view wx:if="{{modes[modeIndex] === '线下'}}" class="field-block">
        <text class="field-label">地点</text>
        <view class="field-box {{form.location ? 'field-value' : ''}} map-picker-box" bindtap="chooseLocation">
          {{form.location || '打开地图选地点'}}
        </view>
      </view>
      <view wx:if="{{modes[modeIndex] === '线下'}}" class="field-block">
        <text class="field-label">谁来买单</text>
        <view class="type-chip-row expense-chip-row">
          <block wx:for="{{expenseOptions}}" wx:key="code">
            <view
              class="type-chip expense-chip {{expenseOptionIndex === index ? 'type-chip-active' : ''}}"
              data-index="{{index}}"
              bindtap="chooseExpenseMode"
            >{{item.label}}</view>
          </block>
        </view>
      </view>
      <view wx:else class="field-block online-tip-block">
        <text class="field-label">地点</text>
        <view class="field-box">线上局不需要选地点</view>
      </view>
    </view>

    <view class="form-card create-card input-card create-card-sand-deep">
      <view class="create-card-accent accent-input"></view>
      <view class="card-caption">补充一句</view>
      <view class="field-block first-field">
        <text class="field-label">备注</text>
        <textarea
          class="textarea-field"
          placeholder="补充一点说明"
          placeholder-class="input-placeholder"
          value="{{form.note}}"
          bindinput="onNoteInput"
          maxlength="200"
        />
      </view>
      <view class="button-stack">
        <button class="primary-button create-submit-button" bindtap="submit">{{submitLabel}}</button>
      </view>
    </view>
  </view>
</view>