.create-stage {
  position: relative;
  min-height: calc(100vh - 64rpx);
  overflow: hidden;
}

.create-orb {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(12rpx);
  opacity: 0.75;
}

.create-orb-left {
  top: 10rpx;
  left: -100rpx;
  width: 280rpx;
  height: 280rpx;
  background: rgba(236, 120, 83, 0.24);
}

.create-orb-right {
  top: 280rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(223, 180, 79, 0.2);
}

.create-wave {
  position: absolute;
  height: 96rpx;
  border-radius: 999rpx;
  opacity: 0.55;
}

.create-wave-top {
  top: 136rpx;
  right: -30rpx;
  width: 280rpx;
  transform: rotate(18deg);
  background: linear-gradient(90deg, rgba(230, 118, 73, 0.18) 0%, rgba(236, 190, 106, 0.3) 100%);
}

.create-wave-bottom {
  top: 680rpx;
  left: -20rpx;
  width: 320rpx;
  transform: rotate(-12deg);
  background: linear-gradient(90deg, rgba(237, 191, 112, 0.16) 0%, rgba(204, 129, 76, 0.24) 100%);
}

.create-dot {
  position: absolute;
  width: 22rpx;
  height: 22rpx;
  border-radius: 7rpx;
  transform: rotate(14deg);
}

.create-dot-a {
  top: 206rpx;
  left: 58rpx;
  background: rgba(220, 122, 68, 0.38);
}

.create-dot-b {
  top: 820rpx;
  right: 72rpx;
  background: rgba(214, 172, 82, 0.38);
}

.create-card {
  position: relative;
  overflow: hidden;
  padding: 30rpx;
  background: linear-gradient(145deg, rgba(255, 250, 243, 0.97) 0%, rgba(247, 236, 222, 0.92) 100%);
  backdrop-filter: blur(8rpx);
  border-radius: 36rpx 94rpx 40rpx 78rpx;
}

.create-card-sunrise {
  background: linear-gradient(145deg, rgba(225, 244, 255, 0.98) 0%, rgba(255, 224, 193, 0.95) 100%);
  box-shadow: 0 24rpx 54rpx rgba(31, 104, 156, 0.15);
}

.create-card-sand {
  background: linear-gradient(145deg, rgba(244, 251, 255, 0.98) 0%, rgba(255, 237, 215, 0.95) 100%);
}

.create-card-clay-soft {
  background: linear-gradient(145deg, rgba(240, 249, 255, 0.98) 0%, rgba(255, 229, 208, 0.95) 100%);
}

.create-card-sand-deep {
  background: linear-gradient(145deg, rgba(235, 246, 255, 0.98) 0%, rgba(255, 218, 185, 0.95) 100%);
}

.create-card-accent {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.accent-header {
  top: -20rpx;
  right: 20rpx;
  width: 170rpx;
  height: 170rpx;
  background: radial-gradient(circle, rgba(31, 182, 244, 0.24) 0%, rgba(255, 137, 36, 0.2) 46%, rgba(230, 154, 77, 0) 72%);
}

.accent-input {
  top: -16rpx;
  right: -14rpx;
  width: 110rpx;
  height: 110rpx;
  background: radial-gradient(circle, rgba(210, 142, 86, 0.14) 0%, rgba(210, 142, 86, 0) 72%);
}

.create-header-card {
  overflow: hidden;
}

.create-decor-controller {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 160rpx;
  height: 160rpx;
  opacity: 0.4;
  transform: rotate(12deg);
  pointer-events: none;
  z-index: 1;
}

.create-header-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.header-badge {
  padding: 10rpx 18rpx;
  border-radius: 18rpx 24rpx 18rpx 26rpx;
  background: rgba(23, 181, 244, 0.12);
  color: #0f7496;
  font-size: 22rpx;
}

.summary-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.topic-panel {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 30rpx 72rpx 34rpx 56rpx;
  background: linear-gradient(135deg, rgba(255, 243, 229, 0.98) 0%, rgba(238, 209, 176, 0.95) 100%);
}

.summary-chip {
  padding: 10rpx 18rpx;
  border-radius: 18rpx 24rpx 18rpx 24rpx;
  background: #f6efe4;
  color: #806e5d;
  font-size: 22rpx;
}

.strong-chip {
  color: #ad5716;
  background: rgba(255, 132, 35, 0.2);
}

.input-card {
  margin-top: 18rpx;
}

.card-caption {
  font-size: 24rpx;
  color: #9a8977;
}

.field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 8rpx;
}

.field-block {
  margin-top: 24rpx;
}

.compact-field {
  margin-top: 0;
}

.first-field {
  margin-top: 14rpx;
}

.field-label {
  font-size: 26rpx;
  color: #6b5e4f;
}

.field-required-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #b85a1d;
}

.compact-header-field {
  margin-top: 0;
}

.header-input-shell {
  margin-top: 16rpx;
  padding: 0 24rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  border-radius: 22rpx 32rpx 22rpx 28rpx;
  background: rgba(255, 251, 246, 0.78);
  border: 1rpx solid rgba(176, 125, 71, 0.14);
  box-sizing: border-box;
}

.header-input-control {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  color: #2e241b;
  font-size: 30rpx;
}

.type-selector-block {
  margin-top: 26rpx;
}

.type-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dice-roll-trigger {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 187, 68, 0.2) 0%, rgba(255, 132, 35, 0.16) 100%);
  border: 1rpx solid rgba(255, 132, 35, 0.2);
  transition: transform 0.15s ease;
}

.dice-roll-trigger:active {
  transform: scale(0.95);
}

.dice-icon {
  font-size: 28rpx;
}

.dice-text {
  font-size: 22rpx;
  color: #b35d23;
}

@keyframes diceShake {
  0%, 100% { transform: rotate(0deg); }
  20% { transform: rotate(-18deg) scale(1.1); }
  40% { transform: rotate(14deg) scale(1.1); }
  60% { transform: rotate(-12deg) scale(1.05); }
  80% { transform: rotate(10deg) scale(1.05); }
}

.dice-shaking {
  animation: diceShake 0.3s ease-in-out infinite;
}

.type-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 16rpx;
}

.type-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 246, 0.7);
  border: 1rpx solid rgba(176, 125, 71, 0.14);
  color: #806e5d;
  font-size: 24rpx;
}

.type-chip-active {
  background: linear-gradient(135deg, rgba(40, 182, 241, 0.16) 0%, rgba(255, 142, 45, 0.22) 100%);
  border-color: rgba(56, 151, 197, 0.18);
  color: #2e241b;
}

.expense-chip-row {
  margin-top: 14rpx;
}

.expense-chip {
  min-width: 148rpx;
  text-align: center;
}

.field-box {
  margin-top: 14rpx;
  padding: 24rpx;
  border-radius: 22rpx 32rpx 22rpx 28rpx;
  background: rgba(255, 251, 246, 0.64);
  color: #8d7c69;
  font-size: 26rpx;
  border: 1rpx solid rgba(176, 125, 71, 0.14);
}

.map-picker-box {
  position: relative;
}

.map-picker-box::after {
  content: '地图选择';
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: #a07f61;
}

.online-tip-block .field-box {
  color: #8d7c69;
}

.field-value {
  color: #2e241b;
}

.button-stack {
  display: flex;
  flex-direction: column;
  margin-top: 32rpx;
}

.input-field,
.textarea-field {
  width: 100%;
  margin-top: 14rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 22rpx 32rpx 22rpx 28rpx;
  background: rgba(255, 251, 246, 0.64);
  border: 1rpx solid rgba(176, 125, 71, 0.14);
  color: #2e241b;
  font-size: 26rpx;
}

.textarea-field {
  min-height: 180rpx;
}

.input-placeholder {
  color: #a89987;
}