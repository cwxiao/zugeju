.archive-detail-shell {
  padding-top: 24rpx;
}

.archive-detail-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.archive-detail-card {
  padding: 30rpx;
  background: rgba(255, 252, 247, 0.96);
}

.archive-detail-hero,
.archive-detail-bill-card {
  background: linear-gradient(145deg, rgba(236, 248, 255, 0.98) 0%, rgba(255, 236, 214, 0.96) 100%);
}

.archive-detail-topline,
.archive-detail-section-head,
.archive-detail-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.archive-detail-status,
.archive-detail-pill,
.archive-detail-bill-button {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 246, 0.78);
  color: #7c6551;
  font-size: 22rpx;
}

.archive-detail-bill-button {
  background: rgba(242, 151, 69, 0.16);
  color: #b96a28;
}

.archive-detail-title {
  display: block;
  margin-top: 24rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #2f2218;
}

.archive-detail-desc,
.archive-detail-note,
.archive-detail-muted {
  display: block;
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #665543;
}

.archive-detail-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.archive-detail-bill-grid {
  margin-top: 18rpx;
}

.archive-detail-metric {
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 251, 246, 0.72);
}

.archive-detail-label,
.archive-detail-row-meta {
  display: block;
  font-size: 22rpx;
  color: #87715d;
}

.archive-detail-value,
.archive-detail-row-title,
.archive-detail-row-amount {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #2f2218;
  font-weight: 600;
}

.archive-detail-total {
  display: block;
  margin-top: 10rpx;
  font-size: 52rpx;
  line-height: 1.15;
  font-weight: 700;
  color: #2f2218;
}

.archive-detail-section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2f2218;
}

.archive-detail-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 18rpx;
}

.archive-detail-row {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0e6d8;
}

.archive-detail-row-amount {
  color: #6b5e4f;
  text-align: right;
}

.archive-detail-row-amount-strong {
  color: #b86122;
}

.archive-detail-member-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.archive-detail-member {
  padding: 20rpx 12rpx;
  border-radius: 24rpx;
  background: rgba(244, 250, 255, 0.82);
  text-align: center;
}

.archive-detail-avatar {
  width: 64rpx;
  height: 64rpx;
  margin: 0 auto 12rpx;
  border-radius: 22rpx;
  background: #e8d2b8;
  color: #5d4127;
  font-size: 24rpx;
  line-height: 64rpx;
}

.archive-detail-member-name {
  display: block;
  font-size: 25rpx;
  color: #2f2218;
  font-weight: 600;
}